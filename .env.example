# MongoDB
MONGO_USER=devgrimoire
MONGO_PASSWORD=change_me_in_production
MONGO_DB=devgrimoire
MONGODB_URI=mongodb://devgrimoire:change_me_in_production@mongodb:27017/devgrimoire?authSource=admin

# Standalone mode (set by docker-compose.standalone.yml, or manually for non-Docker setups)
# MONGODB_STANDALONE=true

# Authentication (leave empty to disable auth entirely)
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_in_production
JWT_SECRET=change_me_generate_a_random_string

# Secrets encryption (required for secret_set / encrypted secrets)
# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=

# Web Push notifications (optional)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
